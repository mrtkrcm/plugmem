# PlugMem service auth. Set this in production and send it as X-API-Key.
PLUGMEM_API_KEY=change-me

# LLM backend (OpenAI-compatible).
# Examples:
#   https://api.openai.com/v1
#   https://openrouter.ai/api/v1
#   http://your-vllm-host:8000/v1
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Optional: use OpenAI embeddings without a separate embedding server.
# If EMBEDDING_BASE_URL is blank and OPENAI_API_KEY is set, PlugMem falls back
# to OpenAI text-embedding-3-small unless EMBEDDING_MODEL overrides it.
OPENAI_API_KEY=

# Optional: dedicated embedding backend.
# Leave blank to use OPENAI_API_KEY fallback or the local deterministic embedder.
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Host port to expose PlugMem on the VM.
PLUGMEM_PORT=8080
