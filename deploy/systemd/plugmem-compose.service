[Unit]
Description=PlugMem stack via docker compose
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/plugmem/deploy/remote
RemainAfterExit=yes
ExecStart=/usr/bin/docker compose --env-file .env up -d --build
ExecStop=/usr/bin/docker compose --env-file .env down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
